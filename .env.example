# ============================================================
# Salin ke .env.local lalu isi dari dashboard Supabase project.
# ============================================================

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Project Settings → API (service_role — RAHASIA, hanya untuk seed)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Project Settings → Database → Connection string → Transaction pooler (port 6543)
# ganti [YOUR-PASSWORD] dengan password database
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Akun admin yang dibuat oleh `npm run seed`
ADMIN_EMAIL=admin@stokdemo.id
ADMIN_PASSWORD=RekonStok2026!

# Pelindung endpoint cron rekonsiliasi harian (samakan dengan env di Vercel)
CRON_SECRET=ganti-dengan-string-acak
